{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.Hosting.Lifetime": "Information"
        }
    },

    "ConnectionStrings": {
        "DefaultConnection": "Server=localhost;Port=${DB_PORT};Database=${DB_NAME};Username=${DB_USER};Password=${DB_PASSWORD};"
    },

    "FileStorage": {
        "BasePath": "/app/files",
        "AllowedExtensions": [ ".jpg", ".png", ".pdf" ],
        "MaxFileSizeMb": 50
    },

    "Server": {
        "IpAddress": "0.0.0.0",
        "Port": 5001
    },

    "Limits": {
        "MaxFileSizeMb": 50,
        "MaxConnections": 100,
        "MaxConnectionsPerIp": 3,
        "RateLimit": {
            "RequestsPerMinute": 60
        }
    }
}
